# Supabase: скопируйте в файл .env и подставьте значения из
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
# Anon JWT (legacy) или publishable: sb_publishable_…
VITE_SUPABASE_ANON_KEY=
# То же самое ключом с новым именем (если ANON_KEY не задан):
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Необязательно (шаблон AI Studio):
# GEMINI_API_KEY=
# APP_URL=
